[Unit]
Description=BIST Scanner API
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/bist-scanner/backend
ExecStart=/opt/bist-scanner/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
